{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Torizon WSL Distro Manifest Schema",
    "allOf": [
        {
            "$ref": "../../gaia/schema/distro.json"
        }
    ],
    "properties": {
        "machine": {
            "description": "The machine type",
            "type": "string",
            "enum": [
                "qemux86-64",
                "qemuarm64",
                "wsl-amd64",
                "wsl-arm64",
                "rpi4b",
                "rpi5b",
                "imx8mp-verdin",
                "imx93-frdm",
                "imx95-verdin-evk",
                "smarc-imx95",
                "intel",
                "sl1680",
                "sl2619",
                "luna"
            ]
        }
    }
}
